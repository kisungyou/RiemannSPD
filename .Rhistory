p = 5
K = 10
spdlist = list()
for (k in 1:K){
nsam = sample(20:30, 1)
tmplist = list()
for (i in 1:nsam){
tmplist[[i]] = cov(matrix(rnorm(20*p), ncol=p))
}
spdlist[[k]] = spd.wrap(tmplist)
}
hoit = spd.harmony14N(spdlist)
hoit$mean.class
