library(RiemannSPD)
A = cov(matrix(rnorm(10*5),ncol=5))
B = cov(matrix(runif(10*5),ncol=5))
C = A%*%B
isSymmetric(C)
det(A%*%B)
log(det(A%*%B))
inv(A+B)
solve(A+B)
solve(A)+solve(B)
