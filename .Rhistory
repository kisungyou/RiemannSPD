library(RiemannSPD)
dat3d = array(0,c(5,5,10))
for (i in 1:10){
dat3d[,,i] = cov(matrix(rnorm(20*5), ncol=5))
}
spdobj = spd.wrap(dat3d)
est1 = spd.mean(spdobj, geometry="pross")
est2 = shapes::estSS(dat3d)
est2
est1
spd.mean(spdobj, geometry="lerm")
