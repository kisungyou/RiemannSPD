image(meanLERM$mean, main=paste0("LERM:",round(meanLERM$variation,3)))
image(meanEUCL$mean, main=paste0("EUCL:",round(meanEUCL$variation,3)))
image(meanCHOL$mean, main=paste0("CHOL:",round(meanCHOL$variation,3)))
